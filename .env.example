# LLM API (one of these required for eval + query understanding)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Infrastructure (defaults work with docker-compose)
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Corpus
CORPUS_DIR=./data/wiki10k

# Optional: enable CLIP for module 08
ENABLE_MULTIMODAL=false
